# ================================================================
#   SCHOOL SPACE — ENVIRONMENT CONFIGURATION
# ================================================================
#
#   Copy this file to .env and fill in your values:
#     cp .env.example .env
#
#   NEVER commit the .env file to git (it contains secrets).
#   This .env.example is safe to commit as a reference.
#
# ================================================================


# ── DATABASE ─────────────────────────────────────────────────────
#
#   MySQL connection string for Prisma ORM.
#
#   Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
#
#   If your password contains special characters, URL-encode them:
#     @ → %40    # → %23    $ → %24    & → %26
#     Example: "Pass@123" → "Pass%40123"
#
#   Default MySQL port is 3306.
#   Create the database first: mysql -u root -p -e "CREATE DATABASE schooldb;"

DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/schooldb"


# ── AUTHENTICATION ───────────────────────────────────────────────
#
#   JWT secret key for signing authentication tokens.
#   Must be a long random string (32+ characters).
#   All active sessions become invalid if you change this.
#
#   Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET="replace_with_a_strong_random_secret_at_least_32_characters"


# ── EMAIL (SMTP) ────────────────────────────────────────────────
#
#   Used for: OTP verification, password reset, grade sheet emails,
#   complaint notifications, school code recovery.
#
#   For Gmail:
#     1. Enable 2-Factor Authentication on your Google account
#     2. Go to: https://myaccount.google.com/apppasswords
#     3. Generate an App Password (16-character code)
#     4. Use that as EMAIL_PASS (not your regular Gmail password)
#
#   If not configured, the system uses Ethereal test email (dev only).
#   Password reset works without email in dev mode (codes shown in UI).

EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password


# ── SERVER ──────────────────────────────────────────────────────
#
#   Backend server port. Default: 8080
#   macOS users: don't use 5000 (reserved by AirPlay).
#
#   NODE_ENV controls:
#     - development: password reset auto-approves, codes shown in UI
#     - production: requires admin approval for password resets

PORT=8080
NODE_ENV=development


# ── CLOUDINARY (Study Material Storage) ─────────────────────────
#
#   Cloud storage for study material videos and thumbnails.
#   When configured, uploads go to Cloudinary instead of local disk.
#   When empty, files are stored locally in backend/uploads/.
#
#   Setup:
#     1. Sign up at https://cloudinary.com (free: 25GB storage)
#     2. Go to Dashboard → copy Cloud Name, API Key, API Secret
#     3. Fill in below
#
#   Files are stored under:
#     Videos:     school-space/materials/
#     Thumbnails: school-space/thumbnails/

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ── GOOGLE OAUTH (Optional) ─────────────────────────────────────
#
#   For Google Sign-In button on login page.
#   Currently partial — backend works, frontend button not wired.
#
#   Setup:
#     1. Go to https://console.cloud.google.com
#     2. Create project → APIs & Services → Credentials
#     3. Create OAuth 2.0 Client ID (Web application)
#     4. Add http://localhost:3000 as Authorized Origin
#
#   Also add to frontend/.env:
#     VITE_GOOGLE_CLIENT_ID=your_client_id_here

GOOGLE_CLIENT_ID=


# ================================================================
#   QUICK REFERENCE
# ================================================================
#
#   Required for basic operation:
#     DATABASE_URL    ← must be set
#     JWT_SECRET      ← must be set
#     PORT            ← defaults to 8080
#
#   Required for emails (OTP, grade sheets):
#     EMAIL_USER      ← Gmail address
#     EMAIL_PASS      ← Gmail App Password
#
#   Optional enhancements:
#     CLOUDINARY_*    ← cloud storage for videos
#     GOOGLE_CLIENT_ID ← Google OAuth login
#     NODE_ENV        ← set to 'production' for prod
#
# ================================================================
